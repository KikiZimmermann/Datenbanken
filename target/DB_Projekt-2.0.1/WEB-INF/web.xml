<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="http://java.sun.com/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_3_0.xsd"
         version="3.0">

  <servlet>
    <servlet-name>NeuerWein</servlet-name>
    <servlet-class>net.DBProjekt.dbs.theater.NeuerWein</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>NeuerWein</servlet-name>
    <url-pattern>/NeuerWein</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>Login</servlet-name>
    <servlet-class>net.DBProjekt.dbs.theater.Login</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>Login</servlet-name>
    <url-pattern>/Login</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>Logout</servlet-name>
    <servlet-class>net.DBProjekt.dbs.theater.Logout</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>Logout</servlet-name>
    <url-pattern>/Logout</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>Reservierung</servlet-name>
    <servlet-class>net.DBProjekt.dbs.theater.Reservierung</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>Reservierung</servlet-name>
    <url-pattern>/Reservierung</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>Ausleihen</servlet-name>
    <servlet-class>net.DBProjekt.dbs.theater.Ausleihen</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>Ausleihen</servlet-name>
    <url-pattern>/Ausleihen</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>StorniereReservierung</servlet-name>
    <servlet-class>net.DBProjekt.dbs.theater.StorniereReservierung</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>StorniereReservierung</servlet-name>
    <url-pattern>/StorniereReservierung</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>Zurueckgeben</servlet-name>
    <servlet-class>net.DBProjekt.dbs.theater.Zurueckgeben</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>Zurueckgeben</servlet-name>
    <url-pattern>/Zurueckgeben</url-pattern>
  </servlet-mapping>

  <filter>
    <filter-name>AuthFilter</filter-name>
    <filter-class>net.DBProjekt.dbs.theater.AuthFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <welcome-file-list>
    <welcome-file>login.jsp</welcome-file>
  </welcome-file-list>

  <session-config>
    <session-timeout>30</session-timeout>
  </session-config>
</web-app>
